# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:8080
API_RATE_LIMIT_PER_MINUTE=600
AUTH_RATE_LIMIT_PER_MINUTE=20
VERIFICATION_RATE_LIMIT_PER_MINUTE=10

# PostgreSQL (DATABASE_URL takes precedence when provided)
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=SpeedFeastMain
PGUSER=postgres
PGPASSWORD=replace-me
PGSSLMODE=disable
PGSSL_REJECT_UNAUTHORIZED=true
PGPOOL_MAX=10
PGPOOL_IDLE_TIMEOUT_MS=30000
PGPOOL_CONNECTION_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=30000
PGAPPNAME=speedfeast-backend

# Request signing and authentication
HMAC_SECRET_KEY=replace-me
JWT_SECRET_KEY=replace-me
JWT_EXPIRES_IN=7d
MERCHANT_JWT_EXPIRES_IN=12h

# Product image storage. Use local only for development.
IMAGE_STORAGE_PROVIDER=local
IMAGE_S3_BUCKET=
IMAGE_PUBLIC_BASE_URL=
AWS_REGION=ca-central-1

# Stripe
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://buyer.example.com/payment-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://buyer.example.com/payment-cancel?session_id={CHECKOUT_SESSION_ID}

# Firebase Cloud Messaging: use either JSON or the three individual fields.
FCM_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Verification providers
SENDGRID_API_KEY=
SMS_PROVIDER=demo
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Rewards
REWARD_POINTS_PER_CAD=1
