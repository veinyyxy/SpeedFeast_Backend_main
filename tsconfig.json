{
  "compilerOptions": {
    "allowJs": true,      // 允许编译 JS 文件
    "checkJs": true,      // 对 JS 文件进行类型检查（可选）
    "outDir": "./public/out",   // 输出目录
    "rootDir": "./public/verification",
    "target": "ES2015",
    "lib": ["ES2015", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "module": "commonjs"  // 模块系统
  },
  "include": ["public/verification/**/*.ts"]
}
